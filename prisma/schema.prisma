generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ENUMS

enum Role {
  CUSTOMER
  RESTAURANT_ADMIN
  SUPER_ADMIN
}

enum MenuCategory {
  MAKANAN
  MINUMAN
  DESSERT
  SNACK
}

//TAMBAHAN ENUM: Klasifikasi format pelayanan untuk kebutuhan perhitungan SPK
enum RestaurantCategory {
  FAST_FOOD
  CAFE_COFFEE
  FAMILY_FRIENDLY
  FINE_DINING
}

enum FasilitasName {
  AC
  MUSHOLA
  KAMAR_MANDI
  WIFI
  SMOKING_AREA
}

// MODELS

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ratings             Rating[]
  rekomendasiRequests RekomendasiRequest[]
  restaurant          Restaurant?

  @@map("users")
}

model Restaurant {
  id          Int      @id @default(autoincrement())
  name        String
  address     String
  description String?  @db.Text
  imageUrl    String?  @db.Text
  phone       String?
  openTime    String?
  closeTime   String?
  adminId     Int      @unique
  admin       User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  // 🛠️ TAMBAHAN FIELD: Menyimpan jenis klasifikasi restoran
  category    RestaurantCategory

  avgPrice        Float @default(0)
  fasilitasScore  Int   @default(0)
  avgFoodKualitas Float @default(0)
  avgKenyamanan   Float @default(0)
  avgEstetika     Float @default(0)
  totalRating     Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menus              Menu[]
  fasilitases        Fasilitas[]
  ratings            Rating[]
  rekomendasiResults RekomendasiHasil[]

  @@index([avgPrice])
  @@index([avgFoodKualitas])
  @@map("restaurants")
}

model Menu {
  id           Int          @id @default(autoincrement())
  restaurantId Int
  name         String
  description  String?      @db.Text
  price        Float
  category     MenuCategory
  imageUrl     String?      @db.Text
  isAvailable  Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, category])
  @@index([price])
  @@map("menus")
}

model Fasilitas {
  id           Int           @id @default(autoincrement())
  restaurantId Int
  name         FasilitasName
  available    Boolean       @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, name])
  @@map("fasilitases")
}

model Rating {
  id           Int @id @default(autoincrement())
  userId       Int
  restaurantId Int

  foodKualitasScore Int
  kenyamananScore   Int
  estetikaScore     Int

  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RELASI USER: Dipakai untuk menarik properti `user.email` saat include di rating logs admin
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([restaurantId])
  @@map("ratings")
}

model RekomendasiRequest {
  id         Int      @id @default(autoincrement())
  userId     Int
  keyword    String?
  maxPrice   Float?
  category   String?
  facilities String?
  createdAt  DateTime @default(now())

  weights RekomendasiWeight[]
  results RekomendasiHasil[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rekomendasi_requests")
}

model RekomendasiWeight {
  id         Int @id @default(autoincrement())
  requestId  Int
  kriteriaId Int
  weight     Float

  request  RekomendasiRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  kriteria Kriteria           @relation(fields: [kriteriaId], references: [id])

  @@unique([requestId, kriteriaId])
  @@map("rekomendasi_weights")
}

model RekomendasiHasil {
  id           Int @id @default(autoincrement())
  requestId    Int
  restaurantId Int
  rank         Int
  wpScore      Float

  request    RekomendasiRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  restaurant Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  details RekomendasiHasilDetail[]

  @@map("rekomendasi_hasil")
}

model RekomendasiHasilDetail {
  id                  Int   @id @default(autoincrement())
  hasilId             Int
  kriteriaId          Int
  skor                Float
  bobot               Float
  nilaiTernormalisasi Float

  hasil    RekomendasiHasil @relation(fields: [hasilId], references: [id], onDelete: Cascade)
  kriteria Kriteria         @relation(fields: [kriteriaId], references: [id])

  @@unique([hasilId, kriteriaId])
  @@map("rekomendasi_hasil_detail")
}

model Kriteria {
  id          Int                      @id @default(autoincrement())
  nama        String                   @unique
  jenis       String
  bobot       Float                    @default(0)
  subKriteria SubKriteria[]
  weights     RekomendasiWeight[]
  hasilDetail RekomendasiHasilDetail[]

  @@map("kriterias")
}

model SubKriteria {
  id         Int    @id @default(autoincrement())
  kriteriaId Int
  keterangan String
  minNilai   Float?
  maxNilai   Float?
  skor       Int

  kriteria Kriteria @relation(fields: [kriteriaId], references: [id], onDelete: Cascade)

  @@map("sub_kriterias")
}


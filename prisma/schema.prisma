generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


// ENUM

enum Role {
  CUSTOMER
  RESTAURANT_ADMIN
  SUPER_ADMIN
}

enum MenuCategory {
  MAKANAN
  MINUMAN
  DESSERT
  SNACK
}

// USER

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ratings             Rating[]
  rekomendasiRequests RekomendasiRequest[]
  restaurant          Restaurant?

  @@map("users")
}


// RESTAURANT

model Restaurant {
  id          Int     @id @default(autoincrement())
  name        String
  address     String
  description String? @db.Text
  imageUrl    String? @db.Text
  phone       String?
  openTime    String?
  closeTime   String?
  adminId     Int     @unique
  admin       User    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  avgPrice        Float @default(0)
  fasilitasScore  Int   @default(0)
  avgFoodKualitas Float @default(0)
  avgKenyamanan   Float @default(0)
  avgEstetika     Float @default(0)
  totalRating     Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menus              Menu[]
  fasilitases        Fasilitas[]
  ratings            Rating[]
  rekomendasiResults RekomendasiHasil[]

  @@index([avgPrice])
  @@index([avgFoodKualitas]) // ← sesuai nama kolom
  @@map("restaurants")
}


// MENU

model Menu {
  id           Int          @id @default(autoincrement())
  restaurantId Int
  name         String
  description  String?      @db.Text
  price        Float
  category     MenuCategory
  imageUrl     String?      @db.Text
  isAvailable  Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, category])
  @@index([price])
  @@map("menus")
}


// FASILITAS

model Fasilitas {
  id           Int     @id @default(autoincrement())
  restaurantId Int
  name         String
  available    Boolean @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, name])
  @@map("fasilitases")
}


// RATING

model Rating {
  id           Int @id @default(autoincrement())
  userId       Int
  restaurantId Int

  foodKualitasScore Int
  kenyamananScore   Int
  estetikaScore     Int

  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([restaurantId])
  @@map("ratings")
}


// REKOMENDASI REQUEST
// Dibuat oleh CUSTOMER setiap kali submit form "Konfigurasi Perhitungan"

model RekomendasiRequest {
  id         Int      @id @default(autoincrement())
  userId     Int
  keyword    String?
  maxPrice   Float?
  category   String?
  facilities String?
  createdAt  DateTime @default(now())

  weights RekomendasiWeight[]
  results RekomendasiHasil[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rekomendasi_requests")
}


// REKOMENDASI WEIGHT
// Bobot tiap kriteria (C1-C5) yang diinput customer, per request

model RekomendasiWeight {
  id         Int   @id @default(autoincrement())
  requestId  Int
  kriteriaId Int
  weight     Float

  request  RekomendasiRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  kriteria Kriteria           @relation(fields: [kriteriaId], references: [id])

  @@unique([requestId, kriteriaId])
  @@map("rekomendasi_weights")
}


// REKOMENDASI HASIL
// Summary hasil akhir WP: ranking + skor per restoran, per request

model RekomendasiHasil {
  id           Int   @id @default(autoincrement())
  requestId    Int
  restaurantId Int
  rank         Int
  wpScore      Float

  request    RekomendasiRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  restaurant Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  details RekomendasiHasilDetail[]

  @@map("rekomendasi_hasil")
}


// REKOMENDASI HASIL DETAIL
// Breakdown skor per-kriteria per-restoran, dipakai untuk menampilkan
// tabel perhitungan SPK di FE (skor mentah, bobot yang dipakai, dan
// nilai ternormalisasi / skor^bobot sesuai rumus WP)

model RekomendasiHasilDetail {
  id                  Int   @id @default(autoincrement())
  hasilId             Int
  kriteriaId          Int
  skor                Float // nilai 1-5: dari SubKriteria (harga), fasilitasScore, atau avg rating
  bobot               Float // salinan weight yang dipakai saat perhitungan ini
  nilaiTernormalisasi Float // skor ^ bobot (komponen vektor S sebelum dibagi total)

  hasil    RekomendasiHasil @relation(fields: [hasilId], references: [id], onDelete: Cascade)
  kriteria Kriteria         @relation(fields: [kriteriaId], references: [id])

  @@unique([hasilId, kriteriaId])
  @@map("rekomendasi_hasil_detail")
}


// KRITERIA
// Master data 5 kriteria: Harga, Fasilitas, FoodKualitas, Kenyamanan, Estetika
// field `bobot` = nilai default yang tampil di FE sebelum customer mengubahnya sendiri

model Kriteria {
  id          Int    @id @default(autoincrement())
  nama        String @unique
  jenis       String // "cost" atau "benefit"
  bobot       Float  @default(0)

  subKriteria SubKriteria[]
  weights     RekomendasiWeight[]
  hasilDetail RekomendasiHasilDetail[]

  @@map("kriterias")
}


// SUB KRITERIA
// Rentang nilai -> skor. Saat ini HANYA dipakai untuk kriteria "Harga"
// (Fasilitas, FoodKualitas, Kenyamanan, Estetika sudah punya skala 1-5
// langsung dari data lain, jadi tidak butuh baris di tabel ini)

model SubKriteria {
  id         Int    @id @default(autoincrement())
  kriteriaId Int
  keterangan String // contoh: "Rp 0 - Rp 10.000"
  minNilai   Float? // 0
  maxNilai   Float? // 10000
  skor       Int    // 1-5

  kriteria Kriteria @relation(fields: [kriteriaId], references: [id], onDelete: Cascade)

  @@map("sub_kriterias")
}